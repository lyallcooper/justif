  "scripts": {
    "build": "tsup && node tools/lower-dist.mjs",
    "build:demo": "npm run build && node tools/build-demo.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.core.json --noEmit",
    "compare:tex": "node tools/tex-compare.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "version": "npm run build && node tools/sync-version.mjs && git add README.md"
  },
  "keywords": [
    "typography",
    "justification",
    "knuth-plass",
    "microtype",
    "line-breaking",
    "hyphenation"
  ],
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-destructuring": "^8.0.1",
    "@babel/plugin-transform-parameters": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "pdfjs-dist": "^6.1.200",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "unpkg": "./dist/auto.js",
  "jsdelivr": "./dist/auto.js"
